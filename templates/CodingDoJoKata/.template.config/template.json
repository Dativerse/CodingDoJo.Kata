{
  "$schema": "http://json.schemastore.org/template",
  "author": "CodingDoJo",
  "classifications": ["Web", "API", "Kata"],
  "identity": "CodingDoJo.Kata.WebApi",
  "name": "Coding DoJo Kata Web API",
  "shortName": "kata",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "KataName",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "KataName/KataName.csproj" },
    { "path": "KataName.Tests/KataName.Tests.csproj" }
  ],
  "symbols": {
    "Framework": {
      "type": "parameter",
      "description": "The target framework for the project.",
      "datatype": "choice",
      "choices": [
        {
          "choice": "net9.0",
          "description": "Target .NET 9.0"
        },
        {
          "choice": "net8.0",
          "description": "Target .NET 8.0"
        }
      ],
      "replaces": "net9.0",
      "defaultValue": "net9.0"
    },
    "skipRestore": {
      "type": "parameter",
      "datatype": "bool",
      "description": "If specified, skips the automatic restore of the project on create.",
      "defaultValue": "false"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**",
            "**/*.user"
          ]
        }
      ]
    }
  ],
  "postActions": [
    {
      "id": "restore",
      "condition": "(!skipRestore)",
      "description": "Restore NuGet packages required by this project.",
      "manualInstructions": [{ "text": "Run 'dotnet restore'" }],
      "actionId": "210D431B-A78B-4D2F-B762-4ED3E3EA9025",
      "continueOnError": true
    },
    {
      "id": "add-to-solution",
      "description": "Add projects to solution",
      "manualInstructions": [{ "text": "Run 'dotnet sln add' for each project" }],
      "actionId": "D396686C-DE0E-4DE6-906D-291CD29FC5DE",
      "continueOnError": true
    }
  ]
}
